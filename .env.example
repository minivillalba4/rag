# Ollama server
OLLAMA_BASE_URL=http://localhost:11434

# Modelos
OLLAMA_MODEL=qwen2.5:7b-instruct
EMBED_MODEL=nomic-embed-text

# Retrieval / chunking
TOP_K=4
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Rutas
DATA_DIR=data/sources
INDEX_DIR=data/index

# Gradio
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
