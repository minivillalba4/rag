# Copia este archivo a `.env` y ajusta los valores que necesites.
# Todos tienen defaults razonables; está aquí por documentación.

# --- Proveedores ---
# LLM:    "ollama" (local)  |  "groq" (API gratuita, necesita GROQ_API_KEY)
# EMBED:  "ollama" (local)  |  "huggingface" (modelo local CPU, sin API)
LLM_PROVIDER=ollama
EMBED_PROVIDER=ollama

# --- Ollama (si LLM_PROVIDER=ollama o EMBED_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
EMBED_MODEL=nomic-embed-text

# --- Groq (si LLM_PROVIDER=groq) ---
# Clave gratis en https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- HuggingFace embeddings locales (si EMBED_PROVIDER=huggingface) ---
# Opciones:
#   sentence-transformers/all-MiniLM-L6-v2                         ~22 MB, solo inglés
#   sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2    ~470 MB, multilingüe
HF_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Retrieval ---
TOP_K=4
CHUNK_SIZE=500
CHUNK_OVERLAP=50
HISTORY_WINDOW=6

# --- Reranker cruzado (opcional, pesado) ---
ENABLE_RERANKER=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RETRIEVER_FETCH_K=20

# --- Rutas ---
DATA_DIR=./data/sources
INDEX_DIR=./data/index

# --- Gradio ---
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860

# --- Logging ---
LOG_LEVEL=INFO

# --- Evaluación (opcional) ---
EVAL_JUDGE_MODEL=
